# ServerD self-hosted runner: 走 Mihomo 代理 + GitHub SSH(443)
# 每个实例一份：cp ... /opt/actions-runner/runner1/.env（runner2/3 同理）
# cd /opt/actions-runner/runner1 && sudo ./svc.sh stop && sudo ./svc.sh start

HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890
ALL_PROXY=socks5://127.0.0.1:7891
NO_PROXY=127.0.0.1,localhost,100.64.0.0/10,.aliyuncs.com,.personal.cr.aliyuncs.com

# 可选：apiserver OSS STS 临时凭证（CD 打部署包时注入 config.prod.env）
# OSS_SESSION_TOKEN=your-sts-session-token
